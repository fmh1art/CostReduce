# Experiment outputs and benchmark results
results/
results_*/

# Benchmark datasets and external repos (large files, not to be committed)
benchmark/*/datasets/
benchmark/*/data/
benchmark/DBA-bench/DataAgentBench/
benchmark/DBA-bench/harbor/datasets/

# Independently versioned paper repository
_latex/

# Archived or historical local working data
_his/
.evolve_skills/
.evolve_tools_his/
.evolve_scripts/
.evolve_scripts_v3_*/

# Temporary workspaces, caches, and generated runtime state
tmp/
temp/
.cache/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Python generated files
__pycache__/
*.py[cod]
*$py.class

# Logs and runtime artifacts
logs/
*.log
*.tmp
*.temp

# Local environment and secrets
.env
.env.*
!.env.example
*.token
*.key
*.pem
