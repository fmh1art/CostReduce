{
    "name": "build_check",
    "description": "Run build/vet/test for Go (auto-sets PATH/GOPATH/CGO_ENABLED=0), TypeScript (tsc) with custom compiler flags, or Python syntax check.",
    "entrypoint": "main.sh",
    "parameters": [
        {"name": "target", "type": "string", "required": true, "description": "File or directory to check"},
        {"name": "--build-only|--vet-only|--compile-only", "type": "string", "required": false, "description": "Limit checks to specific phase"},
        {"name": "--tags", "type": "string", "required": false, "description": "Go build tags"},
        {"name": "--goos|--goarch", "type": "string", "required": false, "description": "Cross-compilation target"},
        {"name": "--ts", "type": "bool", "required": false, "description": "TypeScript type check"},
        {"name": "--filter", "type": "string", "required": false, "description": "tsconfig project path for --ts"},
        {"name": "--ts-lib=LIB", "type": "string", "required": false, "description": "TypeScript --lib flag (e.g., es2020,dom)"},
        {"name": "--ts-module=MODULE", "type": "string", "required": false, "description": "TypeScript --module flag (e.g., commonjs, esnext)"},
        {"name": "--ts-target=TARGET", "type": "string", "required": false, "description": "TypeScript --target flag (e.g., es2020, esnext)"},
        {"name": "--ts-module-resolution=RES", "type": "string", "required": false, "description": "TypeScript --moduleResolution flag (e.g., node)"},
        {"name": "--ts-skipLibCheck", "type": "bool", "required": false, "description": "Skip .d.ts type checking"},
        {"name": "--ts-esModuleInterop", "type": "bool", "required": false, "description": "Enable esModuleInterop"},
        {"name": "--ts-jsx=JSX", "type": "string", "required": false, "description": "TypeScript --jsx flag (e.g., react-jsx)"},
        {"name": "--python", "type": "bool", "required": false, "description": "Python syntax check"}
    ],
    "examples": [{
        "call": "/app/.preinstalled_scripts/build_check/main.sh /app/test/e2e/specs/i18n/i18n__logged-out-redirect.ts --ts --ts-lib=es2020,dom --ts-esModuleInterop --ts-module-resolution=node --ts-module=commonjs --ts-target=es2020 --ts-skipLibCheck --ts-jsx=react-jsx",
        "expected": "TypeScript type-check the file with specified compiler flags"
    }],
    "cost_saving_rationale": "Replaces multi-step build/vet sequences with one command; auto-sets PATH/GOPATH/CGO_ENABLED=0 for Go, eliminating repeated export PATH=... boilerplate; --ts-* flags eliminate long npx tsc --noEmit --lib ... flag sequences seen in samples, collapsing them into individual named flags, saving command token characters and making flags self-documenting."
}