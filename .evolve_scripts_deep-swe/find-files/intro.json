{
  "name": "find-files",
  "description": "Find files by name pattern with filtering, sorting, head/tail limiting, and result limiting in one step, with --cd to change directory before searching.",
  "entrypoint": "main.sh",
  "parameters": [
    {
      "name": "--cd=DIR, -C DIR",
      "type": "string",
      "required": false,
      "description": "Change to directory before searching (replaces cd + find pattern)"
    },
    {
      "name": "directory",
      "type": "string",
      "required": false,
      "description": "Search root directory (default: .)"
    },
    {
      "name": "-n, --name=PATTERN",
      "type": "string",
      "required": false,
      "description": "Name glob pattern (repeatable)"
    },
    {
      "name": "-t, --type=TYPE",
      "type": "string",
      "required": false,
      "description": "File type: f (file) or d (dir) (default: f)"
    },
    {
      "name": "-d, --max-depth=N",
      "type": "int",
      "required": false,
      "description": "Max directory depth"
    },
    {
      "name": "-l, --limit=N",
      "type": "int",
      "required": false,
      "description": "Max results from start (default: 100, 0=unlimited)"
    },
    {
      "name": "--head=N",
      "type": "int",
      "required": false,
      "description": "Show first N results (same as --limit)"
    },
    {
      "name": "--tail=N",
      "type": "int",
      "required": false,
      "description": "Show last N results"
    },
    {
      "name": "-p, --path=PATH",
      "type": "string",
      "required": false,
      "description": "Path glob filter"
    },
    {
      "name": "-x, --exclude=PATTERN",
      "type": "string",
      "required": false,
      "description": "Exclude path pattern"
    },
    {
      "name": "-i, --case-insensitive",
      "type": "bool",
      "required": false,
      "description": "Case-insensitive name matching"
    },
    {
      "name": "--sort",
      "type": "bool",
      "required": false,
      "description": "Sort output alphabetically"
    },
    {
      "name": "--no-exclude-defaults",
      "type": "bool",
      "required": false,
      "description": "Don't exclude .git/node_modules by default"
    }
  ],
  "examples": [
    {
      "call": "/app/.preinstalled_scripts/find-files/main.sh /project -n \"*.go\" -d 4 -l 50",
      "expected": "Up to 50 .go files within 4 levels deep under /project"
    }
  ],
  "cost_saving_rationale": "Collapses find+sort+head/tail piping and custom exclusion logic into one step, saving step count and tool call characters; --cd replaces cd + find two-step pattern."
}
